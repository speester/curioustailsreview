<script>
(function(){
  "use strict";

  /* ---------------- Configuration ---------------- */
  var GOOGLE_REVIEW_URL = "https://g.page/r/CSQWSMYFGUwLEAE/review";

  /* State */
  var rating = 5;
  var selectedBreed = "";
  var selectedStaff = [];
  var selectedQualities = [];

  function $(id){ return document.getElementById(id); }

  /* ---------------- Sample reviews (CSS avatars, no external images) ---------------- */
  var SAMPLE_REVIEWS = [
    {name:"Wei Ling", color:"#f97316", text:"We'd been looking for a healthy Cavapoo puppy for sale and Curious Tails in Balestier was by far the best. Nelson was so informative and our pup came home with an amazing starter kit!"},
    {name:"Aiman", color:"#f59e0b", text:"Bought our Corgi here and couldn't be happier. Kim patiently shared all the care tips we needed, and the puppy is healthy and vet-checked. Highly recommend this AVS-licensed store."},
    {name:"Priya", color:"#ea580c", text:"Our new Maltipoo is the sweetest! Nelson was incredibly helpful and professional, and the free gifts in the $500+ starter kit were such a lovely surprise."},
    {name:"Marcus", color:"#d97706", text:"Searching for a Shiba Inu puppy for sale in Singapore led us to Curious Tails in Balestier. Great prices, super helpful staff, and a perfectly healthy little pup. Five stars!"},
    {name:"Hui Min", color:"#fb923c", text:"Brought home a gorgeous Bichonpoo. Kim was so knowledgeable and gave us thorough care tips. Lovely, trustworthy AVS-licensed store — highly recommend."},
    {name:"Daniel", color:"#c2410c", text:"Our Cavachon settled in beautifully. The team in Balestier was professional and genuinely caring, and the puppy came healthy and well-checked. Fantastic experience!"},
    {name:"Siti", color:"#f59e0b", text:"Best puppy store in Balestier! We were looking for a Dachshund puppy for sale and Nelson made everything so easy. Loads of free gifts and great advice."},
    {name:"Joel", color:"#fb923c", text:"Got our Corgi from Curious Tails and the whole experience was top-notch. Helpful, informative, fairly priced, and a healthy, happy puppy. Thank you Kim!"}
  ];

  function buildSlider(){
    var track = $("ctTrack");
    function cardHTML(r){
      var initials = r.name.charAt(0).toUpperCase();
      return ''
        + '<div class="ct-card">'
        +   '<div class="ct-avatar" style="background:'+r.color+'">'+initials+'</div>'
        +   '<div>'
        +     '<div class="ct-name">'+r.name+'</div>'
        +     '<div class="ct-stars">★★★★★</div>'
        +     '<div class="ct-text">'+r.text+'</div>'
        +   '</div>'
        + '</div>';
    }
    var html = "";
    // Duplicate the set so the -50% keyframe loops seamlessly
    for(var i=0;i<SAMPLE_REVIEWS.length;i++){ html += cardHTML(SAMPLE_REVIEWS[i]); }
    for(var j=0;j<SAMPLE_REVIEWS.length;j++){ html += cardHTML(SAMPLE_REVIEWS[j]); }
    track.innerHTML = html;
  }

  /* ---------------- Star rating selector ---------------- */
  function setupRating(){
    var stars = $("ctRating").querySelectorAll(".ct-star");
    function paint(n){
      stars.forEach(function(s){
        var v = parseInt(s.getAttribute("data-v"),10);
        s.classList.toggle("ct-on", v <= n);
      });
    }
    stars.forEach(function(s){
      s.addEventListener("click", function(){
        rating = parseInt(this.getAttribute("data-v"),10);
        paint(rating);
      });
      s.addEventListener("mouseenter", function(){
        paint(parseInt(this.getAttribute("data-v"),10));
      });
    });
    $("ctRating").addEventListener("mouseleave", function(){ paint(rating); });
    paint(rating);
  }

  /* ---------------- Breed single-select ---------------- */
  function setupBreeds(){
    var chips = $("ctBreeds").querySelectorAll(".ct-chip");
    chips.forEach(function(chip){
      chip.addEventListener("click", function(){
        chips.forEach(function(c){ c.classList.remove("ct-selected"); });
        this.classList.add("ct-selected");
        selectedBreed = this.getAttribute("data-value");
      });
    });
  }

  /* ---------------- Multi-select ---------------- */
  function setupMultiSelect(gridId, store){
    var items = $(gridId).querySelectorAll(".ct-item");
    items.forEach(function(item){
      item.addEventListener("click", function(){
        var v = this.getAttribute("data-value");
        this.classList.toggle("ct-selected");
        var idx = store.indexOf(v);
        if(idx > -1){ store.splice(idx,1); } else { store.push(v); }
      });
    });
  }

  /* ---------------- Natural list joiner ---------------- */
  function joinNatural(arr){
    if(arr.length === 0) return "";
    if(arr.length === 1) return arr[0];
    if(arr.length === 2) return arr[0]+" and "+arr[1];
    return arr.slice(0,-1).join(", ")+", and "+arr[arr.length-1];
  }

  /* ---------------- AI prompt ---------------- */
  function buildPrompt(){
    var staffText = selectedStaff.length ? joinNatural(selectedStaff) : "the staff";
    var qualText  = selectedQualities.length ? joinNatural(selectedQualities) : "helpful and professional";
    var breed     = selectedBreed || "puppy";

    return [
      "Write a genuine-sounding, human "+rating+"-star Google review (2 to 4 sentences) from the perspective of a happy new puppy owner who PURCHASED (not adopted) their puppy from Curious Tails, a licensed puppy store in Singapore.",
      "Requirements:",
      "- Naturally weave in the phrase \"puppy for sale\" (or a close natural variant like \"looking for a "+breed+" puppy for sale\") inside a real sentence, NOT as a tacked-on keyword.",
      "- Mention the breed by name, e.g. \"our new "+breed+"\".",
      "- Mention the location \"Balestier\" naturally (e.g. \"their store in Balestier\" or \"the best puppy store in Balestier\").",
      "- Weave in the staff member(s): "+staffText+".",
      "- Weave in these qualities: "+qualText+".",
      "- Include trust signals naturally: AVS licensed, a healthy / vet-checked puppy, and a $500+ starter kit (use one or two, do not list all robotically).",
      "It must read like a real customer wrote it. Do NOT keyword-stuff, do NOT repeat keywords awkwardly, and use each key phrase at most once. Vary the sentence structure and word order. No quotation marks, no markdown, no preamble. Start directly with the review text."
    ].join("\n");
  }

  /* ---------------- AI generation (Pollinations.ai) ---------------- */
  function generateWithAI(){
    var url = "https://text.pollinations.ai/prompt/" + encodeURIComponent(buildPrompt());
    return fetch(url, { method:"GET", headers:{ "Accept":"text/plain" } })
      .then(function(res){
        if(!res.ok) throw new Error("Pollinations status "+res.status);
        return res.text();
      })
      .then(function(txt){
        var clean = (txt || "").trim()
          .replace(/^["'\s]+|["'\s]+$/g,"")
          .replace(/\*\*/g,"").replace(/[#`]/g,"");
        if(clean.length < 30) throw new Error("Empty/short AI response");
        return clean;
      });
  }

  /* ---------------- Template fallbacks ---------------- */
  function generateFromTemplates(){
    var breed = selectedBreed || "puppy";
    var staff = selectedStaff.length ? joinNatural(selectedStaff) : "the team";
    var quals = selectedQualities.length ? joinNatural(selectedQualities).toLowerCase() : "helpful and professional";

    var templates = [
      "We'd been searching for a healthy "+breed+" puppy for sale in Singapore, and Curious Tails in Balestier was by far the best. "+staff+" was so "+quals+", and our new "+breed+" came home healthy with an amazing starter kit. Highly recommend this AVS-licensed store!",
      "After looking everywhere for a "+breed+" puppy for sale, we finally found Curious Tails in Balestier and couldn't be happier. "+staff+" made the whole experience easy and was genuinely "+quals+", and our vet-checked "+breed+" settled in beautifully.",
      "Bringing home our new "+breed+" from Curious Tails was wonderful. As an AVS-licensed store in Balestier, they made us feel confident the moment we walked in — "+staff+" was "+quals+", and the $500+ starter kit was such a generous surprise.",
      "If you're looking for a "+breed+" puppy for sale, Curious Tails in Balestier is the place to go. Our pup arrived healthy and vet-checked, "+staff+" was incredibly "+quals+", and we left feeling completely supported as new owners.",
      "Honestly the best puppy store in Balestier! We purchased our "+breed+" here and the experience was seamless — "+staff+" was "+quals+", the puppy was healthy, and being AVS licensed gave us real peace of mind.",
      "We couldn't have asked for a better experience getting our "+breed+". Curious Tails in Balestier had exactly the healthy puppy for sale we'd hoped for, and "+staff+" was "+quals+" from start to finish. Came home with a fantastic starter kit too!"
    ];
    return templates[Math.floor(Math.random()*templates.length)];
  }

  /* ---------------- Render review ---------------- */
  function showReview(text){
    var out = $("ctOutput");
    out.textContent = text;
    out.classList.add("ct-show");

    var counter = $("ctCounter");
    counter.textContent = text.length + " characters";
    counter.classList.remove("ct-hidden");

    $("ctActions").classList.remove("ct-hidden");
    $("ctSteps").style.display = "block";
    buildGoogleButton();
    out.scrollIntoView({ behavior:"smooth", block:"center" });
  }

  /* ---------------- Generate routine ---------------- */
  function runGeneration(btn){
    if(!selectedBreed){ alert("Please pick which breed you brought home first! 🐾"); return; }
    if(selectedStaff.length === 0){ alert("Please select who helped you. 🙂"); return; }
    if(selectedQualities.length === 0){ alert("Please select at least one thing you loved about your visit. ✨"); return; }

    $("ctGenHint").classList.add("ct-hidden");

    var original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="ct-spinner"><i data-lucide="loader-2" style="width:20px;height:20px;"></i></span> Creating magic...';
    refreshIcons();

    generateWithAI()
      .catch(function(){ return generateFromTemplates(); })
      .then(function(review){ showReview(review); })
      .catch(function(){ showReview(generateFromTemplates()); })
      .finally(function(){
        btn.disabled = false;
        btn.innerHTML = original;
        refreshIcons();
      });
  }

  /* ---------------- Google review button ----------------
     Uses a click handler instead of a plain href so the link
     reliably breaks OUT of the WordPress/embed frame.
     (g.page sends X-Frame-Options and refuses to load framed.)
  ------------------------------------------------------- */
  function openGoogleReview(){
    // 1) Try opening a brand-new top-level tab
    var win = window.open(GOOGLE_REVIEW_URL, "_blank", "noopener,noreferrer");
    if(win){ return; }
    // 2) Popup blocked — force navigation at the very top window (escapes the iframe)
    try{
      if(window.top && window.top !== window.self){
        window.top.location.href = GOOGLE_REVIEW_URL;
        return;
      }
    }catch(e){ /* cross-origin top access blocked, fall through */ }
    // 3) Last resort
    window.location.href = GOOGLE_REVIEW_URL;
  }

  function buildGoogleButton(){
    var wrap = $("ctGoogleBtnWrap");
    wrap.innerHTML = "";
    var btn = document.createElement("button");
    btn.type = "button";
    btn.className = "ct-btn ct-google-btn";
    btn.innerHTML = '<span class="ct-gicon">G</span> Post My 5-Star Review on Google';
    btn.addEventListener("click", openGoogleReview);
    wrap.appendChild(btn);
    refreshIcons();
  }

  /* ---------------- Copy + toast ---------------- */
  function copyReview(){
    var text = $("ctOutput").textContent;
    function done(){
      showToast();
      $("ctCopyHint").classList.add("ct-hidden"); // hide the copy indicator after copying
    }
    if(navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(text).then(done).catch(fallbackCopy);
    } else {
      fallbackCopy();
    }
    function fallbackCopy(){
      var ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      try{ document.execCommand("copy"); }catch(e){}
      document.body.removeChild(ta);
      done();
    }
  }

  function showToast(){
    var t = $("ctToast");
    t.classList.add("ct-show");
    setTimeout(function(){ t.classList.remove("ct-show"); }, 3000);
  }

  /* ---------------- Lucide init ---------------- */
  function refreshIcons(){
    try{ if(window.lucide && lucide.createIcons) lucide.createIcons(); }catch(e){}
  }

  /* ---------------- Init ---------------- */
  function init(){
    buildSlider();
    setupRating();
    setupBreeds();
    setupMultiSelect("ctStaff", selectedStaff);
    setupMultiSelect("ctQualities", selectedQualities);

    $("ctGenerateBtn").addEventListener("click", function(){ runGeneration(this); });
    $("ctRegenBtn").addEventListener("click", function(){ runGeneration(this); });
    $("ctCopyBtn").addEventListener("click", copyReview);

    refreshIcons();
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
</body>
</html>
