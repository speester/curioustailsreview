        <span class="ct-chip" data-value="Cavachon">🦴 Cavachon</span>
        <span class="ct-chip" data-value="Dachshund">🌭 Dachshund</span>
        <span class="ct-chip" data-value="Corgi">🐕 Corgi</span>
        <span class="ct-chip" data-value="Shiba Inu">🦊 Shiba Inu</span>
      </div>
    </div>

    <!-- ============ STAFF (multi) ============ -->
    <div class="ct-section">
      <h3><i data-lucide="users" style="width:20px;height:20px;"></i> Who made your day special?</h3>
      <div class="ct-hint"><i data-lucide="mouse-pointer-click" style="width:16px;height:16px;"></i> Tap everyone who helped you</div>
      <div class="ct-grid" id="ctStaff">
        <div class="ct-item" data-value="Nelson">🙋‍♂️ Nelson</div>
        <div class="ct-item" data-value="Kim">🙋‍♀️ Kim</div>
      </div>
    </div>

    <!-- ============ QUALITIES (multi) ============ -->
    <div class="ct-section">
      <h3><i data-lucide="sparkles" style="width:20px;height:20px;"></i> What made your experience great?</h3>
      <div class="ct-hint"><i data-lucide="heart-handshake" style="width:16px;height:16px;"></i> Choose all that apply — the more the better!</div>
      <div class="ct-grid" id="ctQualities">
        <div class="ct-item" data-value="Free Gifts">🎁 Free Gifts</div>
        <div class="ct-item" data-value="Informative">📚 Informative</div>
        <div class="ct-item" data-value="Helpful">🤝 Helpful</div>
        <div class="ct-item" data-value="Care Tips">💡 Care Tips</div>
        <div class="ct-item" data-value="Professional">👔 Professional</div>
        <div class="ct-item" data-value="Great Prices">💰 Great Prices</div>
      </div>
    </div>

    <!-- ============ GENERATE ============ -->
    <div class="ct-action-hint" id="ctGenHint">
      <i data-lucide="arrow-down" style="width:18px;height:18px;"></i>
      Generate your review below!
      <i data-lucide="arrow-down" style="width:18px;height:18px;"></i>
    </div>

    <button class="ct-btn" id="ctGenerateBtn">
      <i data-lucide="sparkles" style="width:20px;height:20px;"></i>
