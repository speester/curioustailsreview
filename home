<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Curious Tails – Leave Us a Review</title>

<!-- Lucide icon library (CDN) -->
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

<style>
/* ============================================================
   CURIOUS TAILS – Google Review Helper
   All CSS scoped under .ct-review to avoid theme conflicts
   ============================================================ */
.ct-review{
  --ct-orange:#f97316;
  --ct-amber:#f59e0b;
  --ct-grad:linear-gradient(135deg,#f97316 0%,#f59e0b 100%);
  --ct-cream:#fffdf8;
  --ct-gold:#f59e0b;
  --ct-gold-soft:#fef3c7;
  --ct-slate:#1e293b;
  --ct-slate-soft:#475569;
  --ct-line:#e2e8f0;
  --ct-radius:18px;
  --ct-shadow:0 10px 30px rgba(15,23,42,.08);
  --ct-shadow-lg:0 18px 45px rgba(249,115,22,.20);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  color:var(--ct-slate);
  line-height:1.6;
  box-sizing:border-box;
}
.ct-review *,.ct-review *::before,.ct-review *::after{box-sizing:border-box;}

.ct-review .ct-container{
  max-width:760px;
  margin:0 auto;
  padding:36px 26px 56px;
  background:linear-gradient(180deg,#fff7ed 0%,#ffffff 40%);
  border-radius:26px;
  position:relative;
  overflow:hidden;
}
/* subtle paw-print background touch */
.ct-review .ct-container::before{
  content:"🐾";
  position:absolute;
  top:14px; right:18px;
  font-size:90px;
  opacity:.05;
  transform:rotate(15deg);
  pointer-events:none;
}

/* ---------- Header ---------- */
.ct-review .ct-header{text-align:center;margin-bottom:30px;position:relative;z-index:1;}
.ct-review .ct-header h1{
  font-size:2.5rem;
  font-weight:800;
  letter-spacing:-.5px;
  background:var(--ct-grad);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
  margin:0 0 12px;
}
.ct-review .ct-header p{
  color:var(--ct-slate-soft);
  font-size:1.08rem;
  max-width:540px;
  margin:0 auto;
}
.ct-review .ct-badges{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-top:16px;}
.ct-review .ct-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:#fff;border:1px solid var(--ct-line);
  color:var(--ct-orange);font-weight:600;font-size:.85rem;
  padding:7px 14px;border-radius:999px;box-shadow:var(--ct-shadow);
}
.ct-review .ct-badge.ct-google{background:var(--ct-grad);color:#fff;border:none;}

/* ---------- Reviews slider ---------- */
/* extra bottom margin so it doesn't touch the next section */
.ct-review .ct-slider{margin:28px 0 48px;overflow:hidden;position:relative;}
.ct-review .ct-slider::before,
.ct-review .ct-slider::after{
  content:"";position:absolute;top:0;bottom:0;width:50px;z-index:2;pointer-events:none;
}
.ct-review .ct-slider::before{left:0;background:linear-gradient(90deg,#fff7ed,transparent);}
.ct-review .ct-slider::after{right:0;background:linear-gradient(270deg,#fff,transparent);}
.ct-review .ct-track{display:flex;width:max-content;animation:ct-scroll 42s linear infinite;}
.ct-review .ct-slider:hover .ct-track{animation-play-state:paused;}
@keyframes ct-scroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}

.ct-review .ct-card{
  width:300px;flex:0 0 auto;margin:0 10px;
  background:var(--ct-cream);
  border:1px solid var(--ct-line);
  border-radius:var(--ct-radius);
  padding:20px;
  box-shadow:var(--ct-shadow);
  display:flex;gap:14px;align-items:flex-start;
}
.ct-review .ct-avatar{
  width:50px;height:50px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-weight:700;font-size:1.1rem;
}
.ct-review .ct-card .ct-name{font-weight:700;color:var(--ct-slate);font-size:.95rem;}
.ct-review .ct-card .ct-stars{color:var(--ct-gold);font-size:.9rem;margin:3px 0 7px;}
.ct-review .ct-card .ct-text{font-size:.86rem;color:var(--ct-slate-soft);line-height:1.45;}

/* ---------- Form sections ---------- */
.ct-review .ct-section{margin-bottom:30px;position:relative;z-index:1;}
.ct-review .ct-section h3{
  font-size:1.22rem;font-weight:700;color:var(--ct-slate);
  display:flex;align-items:center;gap:10px;margin:0 0 6px;
}
.ct-review .ct-section h3 i{color:var(--ct-orange);}
.ct-review .ct-hint{
  font-size:.9rem;color:var(--ct-slate-soft);margin-bottom:14px;
  display:flex;align-items:center;gap:7px;
}
.ct-review .ct-hint i{color:var(--ct-gold);}

/* ---------- Star rating selector ---------- */
.ct-review .ct-rating{
  display:flex;gap:8px;justify-content:center;
  background:var(--ct-cream);border:1px solid var(--ct-line);
  border-radius:var(--ct-radius);padding:18px;box-shadow:var(--ct-shadow);
}
.ct-review .ct-star{
  font-size:2.2rem;line-height:1;cursor:pointer;color:#d6d3d1;
  transition:transform .15s ease,color .15s ease;user-select:none;
}
.ct-review .ct-star:hover{transform:scale(1.18);}
.ct-review .ct-star.ct-on{color:var(--ct-gold);text-shadow:0 2px 8px rgba(245,158,11,.4);}

/* ---------- Selection grids (staff / qualities) ---------- */
.ct-review .ct-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;}
.ct-review .ct-item{
  padding:14px 16px;border:2px solid var(--ct-line);border-radius:14px;
  background:#fff;cursor:pointer;text-align:center;font-weight:600;
  color:var(--ct-slate);position:relative;
  transition:transform .25s cubic-bezier(.175,.885,.32,1.275),
             border-color .2s ease,background .2s ease,box-shadow .2s ease;
}
.ct-review .ct-item:hover{
  border-color:var(--ct-amber);transform:translateY(-3px);
  box-shadow:var(--ct-shadow);
}
.ct-review .ct-item.ct-selected{
  border-color:transparent;background:var(--ct-grad);color:#fff;
  transform:translateY(-3px);box-shadow:var(--ct-shadow-lg);
}
.ct-review .ct-item.ct-selected::after{
  content:"✓";position:absolute;top:-9px;right:-9px;
  width:24px;height:24px;border-radius:50%;
  background:var(--ct-gold);color:#fff;font-size:13px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 3px 10px rgba(245,158,11,.5);
}

/* ---------- Breed chips (single select) ---------- */
.ct-review .ct-chips{display:flex;flex-wrap:wrap;gap:10px;}
.ct-review .ct-chip{
  padding:10px 18px;border:2px solid var(--ct-line);border-radius:999px;
  background:#fff;cursor:pointer;font-weight:600;color:var(--ct-slate);
  display:inline-flex;align-items:center;gap:7px;
  transition:transform .2s ease,border-color .2s ease,background .2s ease,box-shadow .2s ease;
}
.ct-review .ct-chip:hover{border-color:var(--ct-amber);transform:translateY(-2px);box-shadow:var(--ct-shadow);}
.ct-review .ct-chip.ct-selected{border-color:transparent;background:var(--ct-grad);color:#fff;box-shadow:var(--ct-shadow-lg);}

/* ---------- Buttons ---------- */
.ct-review .ct-btn{
  width:100%;border:none;cursor:pointer;border-radius:16px;
  padding:17px 26px;font-size:1.05rem;font-weight:700;
  display:flex;align-items:center;justify-content:center;gap:10px;
  margin:14px 0;min-height:60px;position:relative;overflow:hidden;
  background:var(--ct-grad);color:#fff;box-shadow:var(--ct-shadow-lg);
  transition:transform .2s ease,box-shadow .2s ease,opacity .2s ease;
  text-decoration:none;
}
.ct-review .ct-btn:hover{transform:translateY(-2px);box-shadow:0 22px 50px rgba(249,115,22,.30);}
.ct-review .ct-btn:disabled{opacity:.65;cursor:not-allowed;transform:none;}
.ct-review .ct-btn.ct-secondary{background:#fff;color:var(--ct-orange);border:2px solid var(--ct-orange);box-shadow:var(--ct-shadow);}
.ct-review .ct-btn.ct-secondary:hover{background:#fff7ed;}
.ct-review .ct-btn.ct-google-btn{background:linear-gradient(135deg,#ea580c 0%,#f59e0b 100%);}
.ct-review .ct-btn i,.ct-review .ct-btn .ct-gicon{position:relative;z-index:2;flex-shrink:0;}

.ct-review .ct-btn-row{display:flex;gap:12px;flex-wrap:wrap;}
.ct-review .ct-btn-row .ct-btn{flex:1;min-width:160px;margin:14px 0;}

/* spinner */
.ct-review .ct-spinner i{animation:ct-spin 1s linear infinite;display:block;}
@keyframes ct-spin{to{transform:rotate(360deg);}}

/* small Google "G" glyph */
.ct-review .ct-gicon{width:20px;height:20px;background:#fff;border-radius:50%;
  display:inline-flex;align-items:center;justify-content:center;font-weight:800;
  color:var(--ct-orange);font-size:13px;}

/* ---------- Generated review box ---------- */
.ct-review .ct-output{
  display:none;background:var(--ct-cream);border:1px solid var(--ct-line);
  border-left:5px solid var(--ct-gold);border-radius:var(--ct-radius);
  padding:24px;margin:24px 0 6px;font-size:1.08rem;line-height:1.7;
  color:var(--ct-slate);min-height:90px;box-shadow:var(--ct-shadow);
}
.ct-review .ct-output.ct-show{display:block;animation:ct-appear .5s ease-out;}
@keyframes ct-appear{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
.ct-review .ct-counter{font-size:.8rem;color:var(--ct-slate-soft);text-align:right;margin-bottom:4px;}

/* ---------- Action hint indicator ---------- */
.ct-review .ct-action-hint{
  display:flex;align-items:center;justify-content:center;gap:8px;
  color:var(--ct-orange);font-weight:600;font-size:.95rem;
  background:#fff7ed;border:2px dashed var(--ct-amber);
  border-radius:14px;padding:11px;margin:8px 0;
  animation:ct-bob 2s ease-in-out infinite;
}
@keyframes ct-bob{0%,100%{transform:translateY(0);}50%{transform:translateY(-4px);}}

/* ---------- Google steps ---------- */
.ct-review .ct-steps{
  display:none;background:#fff7ed;border:2px dashed var(--ct-orange);
  border-radius:var(--ct-radius);padding:20px;margin:20px 0;
}
.ct-review .ct-steps h4{color:var(--ct-orange);margin:0 0 14px;font-size:1.1rem;
  display:flex;align-items:center;gap:9px;}
.ct-review .ct-step{display:flex;gap:12px;align-items:flex-start;margin-bottom:11px;}
.ct-review .ct-step:last-child{margin-bottom:0;}
.ct-review .ct-num{
  flex-shrink:0;width:26px;height:26px;border-radius:50%;
  background:var(--ct-grad);color:#fff;font-weight:700;font-size:.85rem;
  display:flex;align-items:center;justify-content:center;
}
.ct-review .ct-step-txt{color:var(--ct-slate-soft);font-size:.95rem;padding-top:2px;}

/* ---------- Toast ---------- */
.ct-review .ct-toast{
  position:fixed;top:24px;right:24px;z-index:99999;
  background:var(--ct-grad);color:#fff;font-weight:600;
  padding:14px 22px;border-radius:14px;box-shadow:var(--ct-shadow-lg);
  opacity:0;transform:translateX(120%);transition:all .4s cubic-bezier(.175,.885,.32,1.275);
}
.ct-review .ct-toast.ct-show{opacity:1;transform:translateX(0);}

.ct-review .ct-hidden{display:none !important;}

/* ---------- Footer ---------- */
.ct-review .ct-footer{
  text-align:center;margin-top:34px;padding-top:20px;
  border-top:1px solid var(--ct-line);color:var(--ct-slate-soft);font-size:.85rem;
}

/* ---------- Mobile ---------- */
@media (max-width:640px){
  .ct-review .ct-container{padding:26px 14px 44px;border-radius:18px;}
  .ct-review .ct-header h1{font-size:1.9rem;}
  .ct-review .ct-grid{grid-template-columns:1fr 1fr;}
  .ct-review .ct-item{font-size:.9rem;padding:12px 8px;}
  .ct-review .ct-card{width:260px;}
  .ct-review .ct-star{font-size:1.9rem;}
  .ct-review .ct-toast{top:14px;right:14px;left:14px;transform:translateY(-130%);}
  .ct-review .ct-toast.ct-show{transform:translateY(0);}
  .ct-review .ct-btn-row .ct-btn{min-width:100%;}
}
</style>
</head>
<body>

<div class="ct-review">
  <div class="ct-container">

    <!-- ============ HEADER ============ -->
    <div class="ct-header">
      <h1>Help Us Wag More Tails on Google! 🐾</h1>
      <p>Loved your visit to <strong>Curious Tails</strong> — Singapore's trusted, AVS-licensed puppy store in Balestier? Generate a glowing 5-star review in seconds and share the love!</p>
      <div class="ct-badges">
        <span class="ct-badge ct-google"><span class="ct-gicon">G</span> Google Reviews</span>
        <span class="ct-badge"><i data-lucide="shield-check" style="width:16px;height:16px;"></i> AVS Licensed AS24J00046</span>
        <span class="ct-badge"><i data-lucide="map-pin" style="width:16px;height:16px;"></i> Balestier, SG</span>
      </div>
    </div>

    <!-- ============ REVIEWS SLIDER ============ -->
    <div class="ct-slider">
      <div class="ct-track" id="ctTrack"></div>
    </div>

    <!-- ============ STAR RATING SELECTOR ============ -->
    <div class="ct-section">
      <h3><i data-lucide="star" style="width:20px;height:20px;"></i> How would you rate your experience?</h3>
      <div class="ct-rating" id="ctRating">
        <span class="ct-star ct-on" data-v="1">★</span>
        <span class="ct-star ct-on" data-v="2">★</span>
        <span class="ct-star ct-on" data-v="3">★</span>
        <span class="ct-star ct-on" data-v="4">★</span>
        <span class="ct-star ct-on" data-v="5">★</span>
      </div>
    </div>

    <!-- ============ BREED SELECTOR (single) ============ -->
    <div class="ct-section">
      <h3><i data-lucide="dog" style="width:20px;height:20px;"></i> Which breed did you bring home?</h3>
      <div class="ct-hint"><i data-lucide="paw-print" style="width:16px;height:16px;"></i> Pick your new best friend</div>
      <div class="ct-chips" id="ctBreeds">
        <span class="ct-chip" data-value="Cavapoo">🐶 Cavapoo</span>
        <span class="ct-chip" data-value="Maltipoo">🐾 Maltipoo</span>
