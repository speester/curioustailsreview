      <div class="ct-action-hint" id="ctPostHint">
        <i data-lucide="arrow-down" style="width:18px;height:18px;"></i>
        Step 2: Post it on Google
        <i data-lucide="arrow-down" style="width:18px;height:18px;"></i>
